# Copy this file to .env before running
# cp .env.example .env

# LLM backend: ollama (default, local) | cloud (bifrost → AWS Bedrock)
LLM_BACKEND=ollama

# Set to false for Ollama (plain JSON parsing), true for cloud (structured output)
USE_STRUCTURED_OUTPUT=false

# Optional: override Ollama model names (defaults to qwen3.5:9b for both)
# OLLAMA_TRIGGER_MODEL=qwen3.5:9b
# OLLAMA_EVALUATOR_MODEL=qwen3.5:9b
